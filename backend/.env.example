DATABASE_URL="file:./dev.db"
PORT=4000
JWT_SECRET="change-me-in-production-use-a-long-random-string"
JWT_EXPIRES_IN="7d"
CORS_ORIGIN="http://localhost:5173"
UPLOAD_DIR="./uploads"
NODE_ENV="development"

# ─── Production (Render / PostgreSQL) ─────────────────────────
# Sur Render, DATABASE_URL est fourni automatiquement par le
# service PostgreSQL Render.
# En dev local, utilisez une base PostgreSQL locale ou un service
# gratuit comme Neon/Supabase.
# DATABASE_URL="postgres://user:pass@host:5432/mera"

# ─── Providers IA (au moins UN recommandé — sans clé = mode mock) ───────
# Priorité d'utilisation (auto-fallback) : groq > gemini > anthropic > mock
# Forcer un provider spécifique avec LLM_PROVIDER=mock|groq|gemini|anthropic
LLM_PROVIDER=""

# Groq — RECOMMANDÉ — gratuit, rapide (~200ms), pas de carte bancaire requise
# Obtenir la clé : https://console.groq.com/keys (inscription en 30 secondes)
# Free tier : ~14400 requêtes/jour, modèle Llama 3.3 70B
GROQ_API_KEY=""
GROQ_MODEL="llama-3.3-70b-versatile"

# Google Gemini — Fallback gratuit
# Obtenir la clé : https://aistudio.google.com/app/apikey
# Free tier : 1500 requêtes/jour
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-1.5-flash"

# Anthropic Claude (payant — fallback optionnel)
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-opus-4-7"
